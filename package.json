{
  "name": "realdone",
  "version": "0.2.0",
  "description": "Behavioral verification for AI-built web applications",
  "type": "module",
  "bin": {
    "realdone": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "smoke": "pnpm build && node test/smoke.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "fixture": "node benchmarks/fixture-app/server.mjs",
    "capture-report": "node scripts/capture-report.mjs"
  },
  "keywords": [
    "playwright",
    "behavioral-testing",
    "verification",
    "cli",
    "ai-generated-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datzle123/RealDone.git"
  },
  "bugs": {
    "url": "https://github.com/datzle123/RealDone/issues"
  },
  "homepage": "https://github.com/datzle123/RealDone#readme",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.16"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "playwright": "^1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
